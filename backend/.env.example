NODE_ENV=development
PORT=3000

# Base de données
DATABASE_URL=postgresql://rihla:rihla_secret@localhost:5432/rihla

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=changeme_use_256bit_random_secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# AWS S3
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_REGION=eu-west-3
S3_BUCKET=rihla-files

# Firebase FCM
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_SERVICE_ACCOUNT=base64_encoded_json

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# SMTP
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@rihla.ma
SMTP_PASS=your_smtp_password

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173
