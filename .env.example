# ═══════════════════════════════════════════════════════════════
# RIHLA — Production environment variables
# Copy to .env and fill in real values before `docker compose up`
# ═══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=rihla
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=rihla_db

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_to_a_strong_password

# ── Security (generate with: openssl rand -hex 32) ───────────
SECRET_KEY=generate_a_random_32_char_string
JWT_SECRET_KEY=generate_another_random_32_char_string

# ── Anthropic AI ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Admin seed (first boot) ──────────────────────────────────
ADMIN_EMAIL=a.chakir@stours.ma
ADMIN_PASSWORD=Abdo@1937

# ── CORS (comma-separated origins) ───────────────────────────
CORS_ORIGINS=http://localhost,http://localhost:80,https://rihla.stours.ma

# ── Sentry (optional) ────────────────────────────────────────
SENTRY_DSN=
